# API Keys — AI Providers
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GLM_API_KEY=your_glm_api_key_here
KIMI_API_KEY=your_kimi_api_key_here

# Database
# For Docker Compose, set POSTGRES_PASSWORD in .env or docker-compose.yml
DATABASE_URL=postgresql+asyncpg://equity_user:equity_pass_dev@localhost:5432/equity_research
REDIS_URL=redis://localhost:6379

# Application
APP_ENV=development
LOG_LEVEL=INFO

# CRITICAL: SECRET_KEY must be at least 32 characters
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# In production, NEVER use the default - always set via environment variable
SECRET_KEY=your_secret_key_here_change_in_production_MUST_BE_32_CHARS

# Admin emails (comma-separated) - users with these emails get admin privileges
# Set this during initial setup, then remove after creating admin user
ADMIN_EMAILS=

# Data Provider Selection (hot-swappable)
FUNDAMENTALS_PROVIDER=fmp
PRICE_PROVIDER=finnhub
PROFILE_PROVIDER=fmp
NEWS_PROVIDER=finnhub

# Data Provider API Keys
FMP_API_KEY=your_fmp_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHA_VANTAGE_API_KEY=
EODHD_API_KEY=
POLYGON_API_KEY=
